{
  "name": "ade-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic Development Environment desktop shell",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -w node-pty",
    "dev": "electron .",
    "start": "electron .",
    "dist:win": "electron-builder --win nsis",
    "dist:mac": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.agenticdevenv.desktop",
    "productName": "ADE",
    "files": [
      "index.html",
      "renderer.js",
      "electron/**/*",
      "backend/**/*",
      "docs/**/*",
      "README.MD",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  }
}
